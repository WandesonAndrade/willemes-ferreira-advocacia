rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$'); 
    }

    function incoming() { 
      return request.resource.data; 
    }

    function isValidBlogPost(data) {
      return data.title is string && data.title.size() <= 500
          && data.category is string && data.category.size() <= 200
          && data.excerpt is string && data.excerpt.size() <= 3000
          && data.content is string && data.content.size() <= 100000
          && data.image is string && data.image.size() <= 4096
          && data.readTime is string && data.readTime.size() <= 200
          && data.date is string && data.date.size() <= 200;
    }

    function isValidSystemUser(data) {
      return data.name is string && data.name.size() <= 200
          && data.email is string && data.email.size() <= 200
          && data.role is string && (data.role == 'Administrador' || data.role == 'Advogado' || data.role == 'Secretário' || data.role == 'Editor')
          && data.status is string && (data.status == 'Ativo' || data.status == 'Inativo')
          && data.password is string && data.password.size() <= 200
          && data.createdAt is string && data.createdAt.size() <= 200
          && (!('notes' in data) || data.notes is string && data.notes.size() <= 2000);
    }

    match /blog_posts/{postId} {
      allow read: if true;
      
      allow create: if isValidId(postId) && isValidBlogPost(incoming());
      
      allow update: if isValidId(postId) && isValidBlogPost(incoming());
      
      allow delete: if isValidId(postId);
    }

    match /system_users/{userId} {
      allow read: if true;
      
      allow create: if isValidId(userId) && isValidSystemUser(incoming());
      
      allow update: if isValidId(userId) && isValidSystemUser(incoming());
      
      allow delete: if isValidId(userId);
    }
  }
}
